# dependencies
node_modules/
/backend/venv/

# next.js build output — must match any subdirectory
**/.next/
/out/
/build/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
*.db
*.sqlite3

# Python test artifacts
htmlcov/
.coverage
coverage.xml
.pytest_cache/

# Migration helper scripts (one-time use)
backend/migrate_*.py
backend/run_migration.py

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (never commit secrets)
.env
.env.local
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# documentation
/docs/

# kiro IDE files
/.kiro/
/.vscode/

# Jupyter notebooks
*.ipynb

# Uploaded user content (not source code)
backend/uploads/products/*.jpg
backend/uploads/products/*.jpeg
backend/uploads/products/*.png
backend/uploads/products/*.webp
backend/uploads/id_documents/
backend/uploads/profiles/

# SQLite dev DB
backend/agrogebeya.db
